// "Always With Me" from "Spirited Away"
//
// MIDI performance by Youmi Kimura, but
// I modified it a little bit.
//
// If the music doesn't start right away
// for you please click the rewind icon.
//
// I vectorized the picture into beziers
// by hand using InkScape. The rendering
// technique is very rudimentary, but at
// least it does SDF-based antialiasing.


vec2 evalBezier( float t, vec2 v0, vec2 v1, vec2 v2, vec2 v3 )
{
#if 0
    vec2 a0=v0+(v1-v0)*t, a1=v1+(v2-v1)*t, a2=v2+(v3-v2)*t;
    vec2 b0=a0+(a1-a0)*t, b1=a1+(a2-a1)*t;
    return  b0+(b1-b0)*t;
#else
    vec2 v21 = 3.0*(v2-v1);
    vec2 v10 = 3.0*(v1-v0);
    vec2 v03 =     (v0-v3);
    return (((v21-v10)-t*(v03+v21))*t+v10)*t+v0;
#endif    
}

float sig( float x ) { return x<0.0?-1.0:1.0; }

// .x = winding number
// .y = distance
vec2 line( vec2 p, vec2 a, vec2 b, vec2 wd ) 
{
    // sdf
	vec2 pa = p-a;
    vec2 ba = b-a;
    float h = clamp(dot(pa,ba)/dot(ba,ba), 0.0, 1.0);
    wd.y = min(wd.y, length(pa-h*ba));

    // winding number
    wd.x *= max(sig(a.y-p.y)*sig(b.y-p.y),
                sig(pa.x-ba.x*pa.y/ba.y) );
	return wd;
}

// .x = winding number
// .y = distance
vec2 bezier( vec2 p,
             vec2 v0, vec2 v1, vec2 v2, vec2 v3,
             vec2 wd, float bo )
{
    // skip segment if p not falling in its vertical bbox
    float ymi = min(min(v0.y,v1.y),min(v2.y,v3.y));
    float yma = max(max(v0.y,v1.y),max(v2.y,v3.y));
    if( p.y<ymi-bo || p.y>yma+bo ) return wd;

    // subdivide cubic bezier
    const int num = 10; // TODO: make adaptive?
    vec2 a = v0;
    for( int i=1; i<num; i++ )
    {
        float t = float(i)/float(num-1);
        vec2 b = evalBezier(t, v0, v1, v2, v3);
        wd = line(p, a, b, wd);
        a = b;
	}
    return wd;
}

vec3 rgb( int c )
{
    return vec3( (c>>0)&255, (c>>8)&255, (c>>16)&255 );
}

