vec2 getNode( int id )
{
    int d = kPathData[id];
    return vec2( (d&4095), (d>>12)&2047 );
}

//=======================================

#define ZERO min(iFrame,0)

void mainImage(out vec4 fragColor, vec2 fragCoord) 
{
    // coords and zoom animation
    float sca = 1.0 - 0.13*(0.5-0.5*cos(6.283185*iTime/40.0));
    vec2  p = sca*(2.0*fragCoord-iResolution.xy)/iResolution.x;
    p.x = 1292.0 + 1280.0*p.x;
    p.y =  701.0 - 1280.0*p.y;
    float px = sca*2.0*1280.0/iResolution.x;
    float bo = 1.25*px;

    // draw background...
    vec3 col = rgb(0x895A04);

    // ...with stars
    col += vec3(100,75,25)*
           (smoothstep(7.0, 6.0, length(p-vec2(980,1120)))
           +smoothstep(4.0, 3.0, length(p-vec2(890,1150)))
           +smoothstep(4.0, 3.0, length(p-vec2(790,1040)))
           +smoothstep(6.0, 5.0, length(p-vec2(2470,230))));

    // draw bezier paths
    int pathDataOffset = 0;
    for( int j=ZERO; j<kNumPaths; j++ )
    {
        // load path information
        int  pathInfo = kPathData[pathDataOffset+0];
        int  pathNumBeziers = pathInfo>>24;
        int  pathColor = pathInfo & 0x00ffffff;
        vec4 pathBBox = vec4(getNode(pathDataOffset+1),
                             getNode(pathDataOffset+2));
        pathDataOffset += 3;

        // check path's bounding box
        vec2 dis = abs(p-pathBBox.xy)-pathBBox.zw;
        if( max(dis.x,dis.y)<bo )
        {
            // if inside, then render path...
            vec2 sd = vec2(1.0, 10000.0);
            int  of = pathDataOffset;
            vec2 v0 = getNode(of+0);
            // ... one bezier segment at a time
            for( int i=ZERO; i<pathNumBeziers; i++ )
            {
                vec2 v1 = getNode(of+1);
                vec2 v2 = getNode(of+2);
                vec2 v3 = getNode(of+3);
                sd = bezier( p, v0, v1, v2, v3, sd, bo );
                v0 = v3;
                of += 3;
            }
            // ... and colorize with antialiasing
            col = mix( col, rgb(pathColor), sd.x<0.0?1.0:smoothstep(bo,0.0,sd.y));

            // here just to prevent loop unrolling
            if( col.x>1000.0 ) break; 
        }
        
        // jump to next path's data
        pathDataOffset += 1+3*pathNumBeziers;
    }

    // draw letterboxing
    col *= smoothstep(2.0, 0.0, abs(p.y-704.0)-690.0);

    // ouptut color to pixel
    fragColor = vec4(col/255.0,1.0);
} 